{
  "hooks": {
    "mem": {
      "command": "powershell",
      "args": ["-File", "./.claude/create-handoff-memory.ps1"],
      "description": "Create single agent handoff memory"
    },
    "mem all agents": {
      "command": "powershell", 
      "args": ["-File", "./.claude/create-handoff-memory.ps1", "-AllAgents"],
      "description": "Create multi-agent coordination handoff"
    }
  }
}