name: Feature Branch Validation Workflow

on:
  pull_request:
    types: [opened, synchronize, reopened, ready_for_review]
    branches: [ master, main, develop ]
  pull_request_target:
    types: [opened, synchronize, reopened, labeled]
    branches: [ master, main, develop ]

env:
  NODE_VERSION: '18'
  # Feature Branch Validation Configuration
  VALIDATION_TIMEOUT_MINUTES: '25'
  AGENT_NOTIFICATION_TIMEOUT: '15'
  MOBILE_NAV_P0_TIMEOUT: '3'
  # Performance Budgets by Validation Level
  LEVEL_1_TOLERANCE: '0%'
  LEVEL_2_TOLERANCE: '2%'
  LEVEL_3_TOLERANCE: '5%'
  LEVEL_4_TOLERANCE: '10%'

jobs:
  # ============================================
  # SMART BRANCH ANALYSIS & RISK ASSESSMENT
  # ============================================
  smart-branch-analysis:
    name: Smart Branch Analysis & Risk Assessment
    runs-on: ubuntu-latest
    outputs:
      risk-score: ${{ steps.risk-assessment.outputs.risk-score }}
      validation-level: ${{ steps.risk-assessment.outputs.validation-level }}
      feature-scope: ${{ steps.scope-analysis.outputs.feature-scope }}
      changed-files: ${{ steps.change-detection.outputs.changed-files }}
      mobile-nav-changes: ${{ steps.change-detection.outputs.mobile-nav-changes }}
      js-changes: ${{ steps.change-detection.outputs.js-changes }}
      css-changes: ${{ steps.change-detection.outputs.css-changes }}
      html-changes: ${{ steps.change-detection.outputs.html-changes }}
      config-changes: ${{ steps.change-detection.outputs.config-changes }}
      agent-assignments: ${{ steps.agent-assignment.outputs.assignments }}
      
    steps:
      - name: Checkout PR Branch
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event.pull_request.head.sha }}
          fetch-depth: 0

      - name: Change Detection Analysis
        id: change-detection
        run: |
          echo "🔍 Analyzing PR changes for smart validation"
          
          # Get changed files in this PR
          git diff --name-only origin/${{ github.base_ref }}..HEAD > changed-files.txt
          CHANGED_FILES=$(cat changed-files.txt | tr '\n' ',' | sed 's/,$//')
          
          # Categorize file changes
          MOBILE_NAV_CHANGES=$(grep -E 'mobile-navigation|navigation.*mobile|js/.*nav|css/.*nav' changed-files.txt || echo "")
          JS_CHANGES=$(grep -E '\.(js)$' changed-files.txt || echo "")
          CSS_CHANGES=$(grep -E '\.(css)$' changed-files.txt || echo "")
          HTML_CHANGES=$(grep -E '\.(html)$' changed-files.txt || echo "")
          CONFIG_CHANGES=$(grep -E '\.(yml|yaml|json|config)$|package\.json|playwright\.config' changed-files.txt || echo "")
          
          # Output results
          echo "changed-files=$CHANGED_FILES" >> $GITHUB_OUTPUT
          echo "mobile-nav-changes=$MOBILE_NAV_CHANGES" >> $GITHUB_OUTPUT
          echo "js-changes=$JS_CHANGES" >> $GITHUB_OUTPUT
          echo "css-changes=$CSS_CHANGES" >> $GITHUB_OUTPUT
          echo "html-changes=$HTML_CHANGES" >> $GITHUB_OUTPUT
          echo "config-changes=$CONFIG_CHANGES" >> $GITHUB_OUTPUT
          
          # Log change summary
          echo "📊 Change Detection Results:"
          echo "- Mobile Navigation: $(echo "$MOBILE_NAV_CHANGES" | wc -w) files"
          echo "- JavaScript: $(echo "$JS_CHANGES" | wc -w) files"
          echo "- CSS: $(echo "$CSS_CHANGES" | wc -w) files"
          echo "- HTML: $(echo "$HTML_CHANGES" | wc -w) files"
          echo "- Configuration: $(echo "$CONFIG_CHANGES" | wc -w) files"

      - name: Risk Assessment Algorithm
        id: risk-assessment
        run: |
          echo "⚡ Calculating risk score with 4-point algorithm"
          
          # Risk scoring algorithm
          RISK_SCORE=0
          
          # Mobile Navigation Changes: ×4 risk points (P0 priority)
          if [[ -n "${{ steps.change-detection.outputs.mobile-nav-changes }}" ]]; then
            MOBILE_NAV_COUNT=$(echo "${{ steps.change-detection.outputs.mobile-nav-changes }}" | wc -w)
            MOBILE_NAV_POINTS=$((MOBILE_NAV_COUNT * 4))
            RISK_SCORE=$((RISK_SCORE + MOBILE_NAV_POINTS))
            echo "📱 Mobile Nav Risk: +$MOBILE_NAV_POINTS points ($MOBILE_NAV_COUNT files)"
          fi
          
          # JavaScript/CSS Changes: ×3 risk points (performance impact)
          JS_COUNT=$(echo "${{ steps.change-detection.outputs.js-changes }}" | wc -w)
          CSS_COUNT=$(echo "${{ steps.change-detection.outputs.css-changes }}" | wc -w)
          JS_CSS_POINTS=$(((JS_COUNT + CSS_COUNT) * 3))
          RISK_SCORE=$((RISK_SCORE + JS_CSS_POINTS))
          echo "⚡ JS/CSS Risk: +$JS_CSS_POINTS points ($JS_COUNT JS, $CSS_COUNT CSS)"
          
          # HTML Changes: ×2 risk points (visual/accessibility impact)
          HTML_COUNT=$(echo "${{ steps.change-detection.outputs.html-changes }}" | wc -w)
          HTML_POINTS=$((HTML_COUNT * 2))
          RISK_SCORE=$((RISK_SCORE + HTML_POINTS))
          echo "🎨 HTML Risk: +$HTML_POINTS points ($HTML_COUNT files)"
          
          # Configuration Changes: ×1 risk point (build/deployment impact)
          CONFIG_COUNT=$(echo "${{ steps.change-detection.outputs.config-changes }}" | wc -w)
          CONFIG_POINTS=$((CONFIG_COUNT * 1))
          RISK_SCORE=$((RISK_SCORE + CONFIG_POINTS))
          echo "⚙️ Config Risk: +$CONFIG_POINTS points ($CONFIG_COUNT files)"
          
          # Determine validation level based on risk score
          if [[ $RISK_SCORE -le 2 ]]; then
            VALIDATION_LEVEL=1
            LEVEL_DESC="Basic validation (~3 minutes)"
          elif [[ $RISK_SCORE -le 5 ]]; then
            VALIDATION_LEVEL=2
            LEVEL_DESC="Performance validation (~8 minutes)"
          elif [[ $RISK_SCORE -le 8 ]]; then
            VALIDATION_LEVEL=3
            LEVEL_DESC="Cross-browser testing (~15 minutes)"
          else
            VALIDATION_LEVEL=4
            LEVEL_DESC="Full validation with visual regression (~25 minutes)"
          fi
          
          echo "risk-score=$RISK_SCORE" >> $GITHUB_OUTPUT
          echo "validation-level=$VALIDATION_LEVEL" >> $GITHUB_OUTPUT
          
          echo "🎯 Risk Assessment Complete:"
          echo "- Total Risk Score: $RISK_SCORE points"
          echo "- Validation Level: $VALIDATION_LEVEL"
          echo "- Description: $LEVEL_DESC"

      - name: Feature Scope Analysis
        id: scope-analysis
        run: |
          echo "🔬 Analyzing feature scope classification"
          
          FEATURE_SCOPE=""
          
          # Determine primary scope based on changes
          if [[ -n "${{ steps.change-detection.outputs.mobile-nav-changes }}" ]]; then
            FEATURE_SCOPE="mobile-critical"
          elif [[ "${{ steps.risk-assessment.outputs.risk-score }}" -ge 6 ]]; then
            if [[ -n "${{ steps.change-detection.outputs.js-changes }}" ]] && [[ -n "${{ steps.change-detection.outputs.css-changes }}" ]]; then
              FEATURE_SCOPE="performance-impact"
            else
              FEATURE_SCOPE="visual-impact"
            fi
          elif [[ "${{ steps.risk-assessment.outputs.risk-score }}" -ge 3 ]]; then
            FEATURE_SCOPE="functionality-addition"
          else
            FEATURE_SCOPE="low-risk"
          fi
          
          echo "feature-scope=$FEATURE_SCOPE" >> $GITHUB_OUTPUT
          echo "🏷️ Feature Scope: $FEATURE_SCOPE"

      - name: Agent Assignment Logic
        id: agent-assignment
        run: |
          echo "👥 Determining agent assignments based on scope and changes"
          
          ASSIGNMENTS=""
          
          # Core Infrastructure cluster always involved
          ASSIGNMENTS="$ASSIGNMENTS technical-architect"
          
          # Scope-based assignments
          case "${{ steps.scope-analysis.outputs.feature-scope }}" in
            "mobile-critical")
              ASSIGNMENTS="$ASSIGNMENTS mobile-navigation-specialist javascript-behavior-expert testing-validation-specialist"
              ;;
            "performance-impact")
              ASSIGNMENTS="$ASSIGNMENTS performance-optimizer javascript-behavior-expert css-design-systems-expert"
              ;;
            "visual-impact")
              ASSIGNMENTS="$ASSIGNMENTS css-design-systems-expert html-expert-slds solution-architect-slds"
              ;;
            "functionality-addition")
              ASSIGNMENTS="$ASSIGNMENTS javascript-behavior-expert testing-validation-specialist"
              ;;
            "low-risk")
              ASSIGNMENTS="$ASSIGNMENTS testing-validation-specialist"
              ;;
          esac
          
          # Always include security for validation level 3+
          if [[ "${{ steps.risk-assessment.outputs.validation-level }}" -ge 3 ]]; then
            ASSIGNMENTS="$ASSIGNMENTS security-compliance-auditor"
          fi
          
          echo "assignments=$ASSIGNMENTS" >> $GITHUB_OUTPUT
          echo "🎯 Agent Assignments: $ASSIGNMENTS"

  # ============================================
  # MOBILE NAVIGATION P0 SAFETY CHECK
  # ============================================
  mobile-nav-p0-safety:
    name: Mobile Navigation P0 Safety Check
    runs-on: ubuntu-latest
    needs: smart-branch-analysis
    if: contains(needs.smart-branch-analysis.outputs.feature-scope, 'mobile-critical') || needs.smart-branch-analysis.outputs.validation-level >= 4
    timeout-minutes: 3
    
    steps:
      - name: Checkout PR Branch
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event.pull_request.head.sha }}

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: 'npm'

      - name: Install Dependencies
        run: npm ci

      - name: Install Playwright Browsers
        run: npx playwright install chromium

      - name: Start Local Server
        run: |
          npm run dev &
          sleep 10
          curl -f http://localhost:8080 || exit 1

      - name: Critical Mobile Navigation Test
        run: |
          echo "🚨 P0 CRITICAL: Mobile navigation validation for feature branch"
          echo "Changed files: ${{ needs.smart-branch-analysis.outputs.mobile-nav-changes }}"
          echo "Feature scope: ${{ needs.smart-branch-analysis.outputs.feature-scope }}"
          echo "Risk score: ${{ needs.smart-branch-analysis.outputs.risk-score }}"
          
          # Run critical mobile navigation tests
          npm run test:critical-navigation
          
          if [[ $? -eq 0 ]]; then
            echo "✅ Mobile navigation P0 check passed for feature branch"
          else
            echo "❌ CRITICAL: Mobile navigation broken by feature branch changes"
            echo "This is a P0 failure - feature branch cannot be merged"
            exit 1
          fi

      - name: Feature Branch Mobile Nav Failure Alert
        if: failure()
        uses: actions/github-script@v7
        with:
          script: |
            const scope = '${{ needs.smart-branch-analysis.outputs.feature-scope }}';
            const riskScore = '${{ needs.smart-branch-analysis.outputs.risk-score }}';
            const changedFiles = '${{ needs.smart-branch-analysis.outputs.mobile-nav-changes }}';
            const agents = '${{ needs.smart-branch-analysis.outputs.agent-assignments }}';
            
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: `🚨 **FEATURE BRANCH MOBILE NAVIGATION P0 FAILURE**
              
              **Critical Issue**: Mobile navigation functionality is broken by feature branch changes.
              
              **Feature Branch Analysis**:
              - **Risk Score**: ${riskScore}
              - **Feature Scope**: ${scope}
              - **Changed Files**: ${changedFiles.split(',').map(f => f.trim()).filter(f => f).join(', ')}
              
              **Immediate Actions Required**:
              - [ ] **@technical-architect**: Emergency review within 15 minutes (Core Infrastructure lead)
              - [ ] **Agent assignments**: ${agents.split(' ').map(a => '@' + a).join(', ')}
              - [ ] Fix mobile navigation issues before merge approval
              
              **Emergency Rollback Available**: 
              \`\`\`bash
              gh workflow run strategic-rollback.yml -f rollback_type=feature-branch -f reason="Mobile nav P0 failure"
              \`\`\`
              
              **This feature branch cannot be merged until mobile navigation works correctly on all pages.**`
            });

      - name: Upload Mobile Nav Test Reports
        if: always()
        uses: actions/upload-artifact@v3
        with:
          name: mobile-nav-p0-safety-reports-feature-branch
          path: |
            playwright-report/
            test-results/
          retention-days: 30

  # ============================================
  # DYNAMIC VALIDATION LEVELS (1-4)
  # ============================================
  dynamic-validation:
    name: Dynamic Validation (Level ${{ needs.smart-branch-analysis.outputs.validation-level }})
    runs-on: ubuntu-latest
    needs: [smart-branch-analysis, mobile-nav-p0-safety]
    if: always() && (needs.mobile-nav-p0-safety.result != 'failure')
    strategy:
      matrix:
        validation-type: [linting, security, performance, browser-testing, visual-regression]
        
    steps:
      - name: Checkout PR Branch
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event.pull_request.head.sha }}

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: 'npm'

      - name: Install Dependencies
        run: npm ci

      - name: Dynamic Validation Logic
        run: |
          VALIDATION_LEVEL="${{ needs.smart-branch-analysis.outputs.validation-level }}"
          VALIDATION_TYPE="${{ matrix.validation-type }}"
          FEATURE_SCOPE="${{ needs.smart-branch-analysis.outputs.feature-scope }}"
          
          echo "🎯 Running $VALIDATION_TYPE for Validation Level $VALIDATION_LEVEL"
          echo "Feature Scope: $FEATURE_SCOPE"
          
          case $VALIDATION_TYPE in
            "linting")
              # Level 1+: Always run linting
              echo "📝 Running linting validation"
              if [[ -n "${{ needs.smart-branch-analysis.outputs.js-changes }}" ]]; then
                npm run lint:js
              fi
              if [[ -n "${{ needs.smart-branch-analysis.outputs.css-changes }}" ]]; then
                npm run lint:css
              fi
              if [[ -n "${{ needs.smart-branch-analysis.outputs.html-changes }}" ]]; then
                npm run validate:html
              fi
              ;;
              
            "security")
              # Level 1+: Always run security audit
              echo "🔒 Running security audit"
              npm run security
              
              # Level 2+: SLDS compliance for CSS changes
              if [[ $VALIDATION_LEVEL -ge 2 ]] && [[ -n "${{ needs.smart-branch-analysis.outputs.css-changes }}" ]]; then
                echo "📋 Checking SLDS compliance"
                npm run validate:slds
              fi
              ;;
              
            "performance")
              # Level 2+: Performance budget validation
              if [[ $VALIDATION_LEVEL -ge 2 ]]; then
                echo "⚡ Running performance budget validation"
                
                # Set tolerance based on validation level
                case $VALIDATION_LEVEL in
                  2) TOLERANCE="${{ env.LEVEL_2_TOLERANCE }}" ;;
                  3) TOLERANCE="${{ env.LEVEL_3_TOLERANCE }}" ;;
                  4) TOLERANCE="${{ env.LEVEL_4_TOLERANCE }}" ;;
                esac
                
                echo "Performance tolerance for Level $VALIDATION_LEVEL: $TOLERANCE"
                
                npm run dev &
                sleep 10
                npm run test:performance-budget
              else
                echo "⏭️ Skipping performance validation for Level $VALIDATION_LEVEL"
              fi
              ;;
              
            "browser-testing")
              # Level 3+: Cross-browser testing
              if [[ $VALIDATION_LEVEL -ge 3 ]]; then
                echo "🌐 Running cross-browser testing"
                npx playwright install
                npm run dev &
                sleep 10
                
                # Scope-specific browser testing
                if [[ "$FEATURE_SCOPE" == "mobile-critical" ]]; then
                  npx playwright test --grep="Mobile navigation" --project="chromium-mobile firefox-mobile webkit-mobile"
                else
                  npx playwright test --project="chromium firefox webkit"
                fi
              else
                echo "⏭️ Skipping browser testing for Level $VALIDATION_LEVEL"
              fi
              ;;
              
            "visual-regression")
              # Level 4: Full visual regression testing
              if [[ $VALIDATION_LEVEL -ge 4 ]]; then
                echo "📸 Running visual regression testing"
                npx playwright install
                npm run dev &
                sleep 10
                
                # Full visual regression suite
                npx playwright test --grep="visual consistency" --update-snapshots
                
                echo "✅ Visual regression testing complete"
              else
                echo "⏭️ Skipping visual regression for Level $VALIDATION_LEVEL"
              fi
              ;;
          esac

      - name: Upload Validation Reports
        if: always()
        uses: actions/upload-artifact@v3
        with:
          name: validation-reports-${{ matrix.validation-type }}-level-${{ needs.smart-branch-analysis.outputs.validation-level }}
          path: |
            lighthouse-reports/
            pa11y-reports/
            playwright-report/
            test-results/
          retention-days: 30

  # ============================================
  # FEATURE BRANCH MERGE READINESS
  # ============================================
  merge-readiness:
    name: Feature Branch Merge Readiness Assessment
    runs-on: ubuntu-latest
    needs: [smart-branch-analysis, mobile-nav-p0-safety, dynamic-validation]
    if: always()
    outputs:
      merge-ready: ${{ steps.assessment.outputs.merge-ready }}
      validation-summary: ${{ steps.assessment.outputs.validation-summary }}
      agent-approvals-needed: ${{ steps.assessment.outputs.agent-approvals-needed }}
      
    steps:
      - name: Merge Readiness Assessment
        id: assessment
        run: |
          echo "🎯 Assessing feature branch merge readiness"
          
          MERGE_READY="true"
          BLOCKING_ISSUES=""
          
          # Check mobile navigation P0 status
          MOBILE_NAV_RESULT="${{ needs.mobile-nav-p0-safety.result }}"
          if [[ "$MOBILE_NAV_RESULT" == "failure" ]]; then
            MERGE_READY="false"
            BLOCKING_ISSUES="$BLOCKING_ISSUES mobile-navigation-p0-failure"
          fi
          
          # Check dynamic validation results
          VALIDATION_RESULT="${{ needs.dynamic-validation.result }}"
          if [[ "$VALIDATION_RESULT" == "failure" ]]; then
            MERGE_READY="false"
            BLOCKING_ISSUES="$BLOCKING_ISSUES validation-failure"
          fi
          
          # Generate validation summary
          VALIDATION_LEVEL="${{ needs.smart-branch-analysis.outputs.validation-level }}"
          RISK_SCORE="${{ needs.smart-branch-analysis.outputs.risk-score }}"
          FEATURE_SCOPE="${{ needs.smart-branch-analysis.outputs.feature-scope }}"
          
          VALIDATION_SUMMARY="Level $VALIDATION_LEVEL validation completed (Risk: $RISK_SCORE, Scope: $FEATURE_SCOPE)"
          
          # Agent approvals needed
          AGENT_APPROVALS="${{ needs.smart-branch-analysis.outputs.agent-assignments }}"
          
          echo "merge-ready=$MERGE_READY" >> $GITHUB_OUTPUT
          echo "validation-summary=$VALIDATION_SUMMARY" >> $GITHUB_OUTPUT
          echo "agent-approvals-needed=$AGENT_APPROVALS" >> $GITHUB_OUTPUT
          
          echo "🎯 Merge Readiness: $MERGE_READY"
          echo "📊 Validation: $VALIDATION_SUMMARY"
          echo "👥 Approvals Needed: $AGENT_APPROVALS"
          echo "🚫 Blocking Issues: $BLOCKING_ISSUES"

      - name: Feature Branch Status Summary
        uses: actions/github-script@v7
        with:
          script: |
            const mergeReady = '${{ steps.assessment.outputs.merge-ready }}';
            const validationSummary = '${{ steps.assessment.outputs.validation-summary }}';
            const agentApprovals = '${{ steps.assessment.outputs.agent-approvals-needed }}';
            const riskScore = '${{ needs.smart-branch-analysis.outputs.risk-score }}';
            const validationLevel = '${{ needs.smart-branch-analysis.outputs.validation-level }}';
            const featureScope = '${{ needs.smart-branch-analysis.outputs.feature-scope }}';
            
            const statusEmoji = mergeReady === 'true' ? '✅' : '❌';
            const status = mergeReady === 'true' ? 'READY FOR REVIEW' : 'BLOCKED - ISSUES MUST BE RESOLVED';
            
            const commentBody = `## ${statusEmoji} Feature Branch Validation Complete
            
            **Status**: ${status}
            
            ### 🔍 Smart Analysis Results
            - **Risk Score**: ${riskScore} points
            - **Validation Level**: ${validationLevel} (Dynamic validation applied)
            - **Feature Scope**: ${featureScope}
            - **Validation Summary**: ${validationSummary}
            
            ### 🧪 Validation Results
            - **Mobile Navigation P0**: ${{ needs.mobile-nav-p0-safety.result || 'Not Required' }}
            - **Dynamic Validation**: ${{ needs.dynamic-validation.result || 'Completed' }}
            - **Smart Change Detection**: ✅ Completed
            
            ### 👥 Required Agent Approvals
            ${agentApprovals.split(' ').map(agent => \`- **@\${agent}**: Review and approve changes in your domain\`).join('\\n')}
            
            ### 📋 Quality Gates Checklist
            - [ ] Mobile navigation functionality verified (if applicable)
            - [ ] Performance budgets maintained with smart tolerances
            - [ ] Security and compliance scans passed
            - [ ] Agent domain expertise reviews completed
            - [ ] All validation levels completed successfully
            
            ${mergeReady === 'true' ? 
              '🎉 **This feature branch has passed all automated validation and is ready for agent review and merge.**' : 
              '⚠️ **This feature branch has blocking issues that must be resolved before merge.**'}
            
            ### 🚨 Emergency Information
            **Core Infrastructure Lead**: @technical-architect (15-minute SLA for P0 issues)
            **Emergency Rollback**: \`gh workflow run strategic-rollback.yml -f rollback_type=feature-branch\``;
            
            await github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: commentBody
            });

  # ============================================
  # NOTIFICATION & MONITORING
  # ============================================
  feature-branch-completion:
    name: Feature Branch Validation Completion
    runs-on: ubuntu-latest
    needs: [smart-branch-analysis, mobile-nav-p0-safety, dynamic-validation, merge-readiness]
    if: always()
    
    steps:
      - name: Feature Branch Validation Summary
        run: |
          echo "=== Feature Branch Validation Workflow Summary ==="
          echo "Risk Score: ${{ needs.smart-branch-analysis.outputs.risk-score }}"
          echo "Validation Level: ${{ needs.smart-branch-analysis.outputs.validation-level }}"
          echo "Feature Scope: ${{ needs.smart-branch-analysis.outputs.feature-scope }}"
          echo "Mobile Nav P0: ${{ needs.mobile-nav-p0-safety.result }}"
          echo "Dynamic Validation: ${{ needs.dynamic-validation.result }}"
          echo "Merge Ready: ${{ needs.merge-readiness.outputs.merge-ready }}"
          echo "Agent Assignments: ${{ needs.smart-branch-analysis.outputs.agent-assignments }}"
          echo "PR: ${{ github.event.pull_request.number }}"
          echo "Branch: ${{ github.event.pull_request.head.ref }}"
          echo "Author: ${{ github.event.pull_request.user.login }}"
          echo "=============================================="