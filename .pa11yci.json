{
  "defaults": {
    "chromeLaunchConfig": {
      "args": ["--no-sandbox", "--disable-setuid-sandbox"]
    },
    "timeout": 30000,
    "wait": 2000,
    "standard": "WCAG2AA",
    "level": "error",
    "threshold": 0,
    "includeNotices": false,
    "includeWarnings": true,
    "reporter": ["json", "html"],
    "hideElements": ".slds-assistive-text",
    "runners": [
      "htmlcs"
    ],
    "actions": [
      "wait for element #main-content to be visible",
      "screen capture example.png"
    ]
  },
  "urls": [
    {
      "url": "http://localhost:8080/",
      "actions": [
        "wait for element .hero-section to be visible",
        "wait for element .stat-card to be visible",
        "screen capture homepage.png"
      ]
    },
    {
      "url": "http://localhost:8080/about.html",
      "actions": [
        "wait for element main to be visible",
        "screen capture about.png"
      ]
    },
    {
      "url": "http://localhost:8080/services.html",
      "actions": [
        "wait for element main to be visible",
        "screen capture services.png"
      ]
    },
    {
      "url": "http://localhost:8080/impact.html",
      "actions": [
        "wait for element main to be visible",
        "screen capture impact.png"
      ]
    },
    {
      "url": "http://localhost:8080/resources.html",
      "actions": [
        "wait for element main to be visible",
        "screen capture resources.png"
      ]
    },
    {
      "url": "http://localhost:8080/contact.html",
      "actions": [
        "wait for element main to be visible",
        "screen capture contact.png"
      ]
    }
  ]
}