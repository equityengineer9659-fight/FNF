# Environment Configuration Example
# Copy this file to .env.local for local development
# Copy this file to .env.production for production builds

# Environment Type
VITE_ENV=development
VITE_APP_NAME="Food-N-Force"
VITE_APP_VERSION=2.0.0

# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Monitoring & Analytics
VITE_SENTRY_DSN=
VITE_GA_MEASUREMENT_ID=
VITE_LOGROCKET_APP_ID=

# Feature Flags
VITE_FEATURE_NEWSLETTER=true
VITE_FEATURE_PARTICLES=true
VITE_FEATURE_ANIMATIONS=true
VITE_FEATURE_DEBUG_MODE=true

# Performance Settings
VITE_PERFORMANCE_SAMPLE_RATE=1.0
VITE_ERROR_THROTTLE_MS=1000
VITE_MAX_PARTICLE_COUNT=10

# Third-party Services
VITE_MAILCHIMP_URL=
VITE_RECAPTCHA_SITE_KEY=

# Build Settings
VITE_SOURCE_MAP=true
VITE_MINIFY=false

# Security
VITE_CSP_REPORT_URI=
VITE_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080