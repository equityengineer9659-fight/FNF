# Food-N-Force Website Environment Variables
# Copy this file to .env and fill in your actual values

# Netlify Configuration
NETLIFY_AUTH_TOKEN=your_netlify_auth_token_here
NETLIFY_STAGING_SITE_ID=your_staging_site_id_here
NETLIFY_PRODUCTION_SITE_ID=your_production_site_id_here

# Development Configuration
NODE_ENV=development
PORT=8080

# Lighthouse CI Configuration (optional)
LHCI_GITHUB_APP_TOKEN=your_github_app_token_here
LHCI_TOKEN=your_lighthouse_ci_token_here

# GitHub Configuration (for automated issues and releases)
GITHUB_TOKEN=your_github_token_here

# Performance Monitoring (optional)
PERFORMANCE_BUDGET_URL=https://your-performance-monitoring-service.com

# Security Scanning (optional)
SNYK_TOKEN=your_snyk_token_here

# Notification Webhooks (optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Custom Domain Configuration
PRODUCTION_URL=https://foodnforce.com
STAGING_URL=https://staging.foodnforce.com

# Analytics (optional)
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Content Security Policy Reporting (optional)
CSP_REPORT_URI=https://your-csp-reporting-endpoint.com/report