{
  "_comment": "Lighthouse CI config — STRICT thresholds for CI/CD pipeline. For local development, see lighthouse.config.js in project root.",
  "ci": {
    "collect": {
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/about.html",
        "http://localhost:4173/services.html",
        "http://localhost:4173/impact.html",
        "http://localhost:4173/resources.html",
        "http://localhost:4173/contact.html"
      ],
      "startServerCommand": "npm run dev",
      "startServerReadyPattern": "Available on:",
      "startServerReadyTimeout": 30000,
      "numberOfRuns": 3
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", {"minScore": 0.85}],
        "categories:accessibility": ["error", {"minScore": 0.95}],
        "categories:best-practices": ["error", {"minScore": 0.90}],
        "categories:seo": ["error", {"minScore": 0.90}],
        "categories:pwa": "off",
        "first-contentful-paint": ["error", {"maxNumericValue": 2000}],
        "largest-contentful-paint": ["error", {"maxNumericValue": 3000}],
        "cumulative-layout-shift": ["error", {"maxNumericValue": 0.1}],
        "total-blocking-time": ["error", {"maxNumericValue": 300}],
        "speed-index": ["error", {"maxNumericValue": 3000}],
        "interactive": ["error", {"maxNumericValue": 4000}],
        "color-contrast": "error",
        "heading-order": "error",
        "html-has-lang": "error",
        "image-alt": "error",
        "label": "error",
        "link-name": "error",
        "meta-description": "error",
        "meta-viewport": "error",
        "document-title": "error",
        "charset": "error",
        "crawlable-anchors": "error",
        "font-display": "error",
        "uses-responsive-images": "error",
        "efficient-animated-content": "error",
        "unused-css-rules": "warn",
        "uses-text-compression": "error",
        "render-blocking-resources": "warn"
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-reports"
    },
    "server": {
      "port": 8080,
      "host": "localhost"
    }
  }
}