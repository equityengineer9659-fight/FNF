{
  "framework_version": "1.0.0",
  "framework_name": "Performance Optimization Framework",
  "framework_authority": "performance-optimizer + technical-architect",
  "governance_integration": {
    "emergency_response_sla": "15_minutes",
    "authority_matrix": {
      "critical_performance_degradation": "technical-architect",
      "performance_budget_violations": "performance-optimizer", 
      "core_web_vitals_failures": "performance-optimizer",
      "bundle_size_regression": "technical-architect",
      "user_experience_impact": "project-manager-proj"
    },
    "escalation_procedures": {
      "performance_regression": {
        "response_time": "15_minutes",
        "authority": "technical-architect",
        "escalation_path": "Emergency Response Protocol"
      },
      "budget_violation": {
        "response_time": "30_minutes", 
        "authority": "performance-optimizer",
        "escalation_path": "technical-architect"
      },
      "user_impact": {
        "response_time": "1_hour",
        "authority": "project-manager-proj",
        "escalation_path": "Stakeholder Communication"
      }
    }
  },
  "performance_budgets": {
    "core_web_vitals": {
      "largest_contentful_paint": {
        "mobile": 2.5,
        "desktop": 2.0,
        "units": "seconds"
      },
      "first_input_delay": {
        "mobile": 100,
        "desktop": 100,
        "units": "milliseconds"
      },
      "cumulative_layout_shift": {
        "mobile": 0.1,
        "desktop": 0.1,
        "units": "score"
      },
      "first_contentful_paint": {
        "mobile": 1.8,
        "desktop": 1.5,
        "units": "seconds"
      },
      "time_to_interactive": {
        "mobile": 3.8,
        "desktop": 3.0,
        "units": "seconds"
      }
    },
    "resource_budgets": {
      "total_bundle_size": 150000,
      "css_bundle_size": 45000,
      "javascript_bundle_size": 90000,
      "images_total_size": 500000,
      "fonts_total_size": 100000,
      "total_requests": 50
    },
    "performance_targets": {
      "lighthouse_performance_score": 90,
      "page_load_time": 3000,
      "dom_content_loaded": 1500,
      "first_meaningful_paint": 2000,
      "speed_index": 3000,
      "memory_usage_threshold": 52428800
    },
    "nonprofit_specific_targets": {
      "donation_form_load_time": 2000,
      "volunteer_registration_load_time": 2500,
      "accessibility_compliance_performance": true,
      "mobile_first_optimization": true
    }
  },
  "monitoring_configuration": {
    "real_time_monitoring": {
      "enabled": true,
      "sampling_interval": "30_seconds",
      "alert_thresholds": {
        "performance_regression": 20,
        "budget_violation": 10,
        "user_impact_threshold": 5
      }
    },
    "automated_testing": {
      "lighthouse_audits": {
        "frequency": "on_deployment",
        "devices": ["mobile", "desktop"],
        "throttling": "4g_mobile"
      },
      "core_web_vitals": {
        "frequency": "continuous", 
        "real_user_monitoring": true,
        "synthetic_testing": true
      },
      "performance_regression": {
        "baseline_comparison": true,
        "threshold_percentage": 15,
        "automatic_rollback_trigger": 25
      }
    }
  },
  "optimization_strategies": {
    "bundle_optimization": {
      "code_splitting": true,
      "tree_shaking": true,
      "minification": true,
      "compression": "gzip_brotli"
    },
    "resource_optimization": {
      "image_optimization": true,
      "font_optimization": true,
      "css_optimization": true,
      "javascript_optimization": true
    },
    "caching_strategy": {
      "static_assets_cache": "365_days",
      "dynamic_content_cache": "1_hour",
      "api_cache": "5_minutes",
      "cdn_integration": true
    },
    "critical_path_optimization": {
      "inline_critical_css": true,
      "defer_non_critical_js": true,
      "preload_critical_resources": true,
      "eliminate_render_blocking": true
    }
  },
  "emergency_response": {
    "performance_degradation": {
      "automatic_rollback_threshold": 30,
      "emergency_contact": "technical-architect",
      "rollback_window": "15_minutes",
      "incident_documentation": true
    },
    "budget_violation_response": {
      "immediate_alerts": true,
      "automatic_deployment_blocking": true,
      "remediation_tracking": true,
      "authority_notification": "performance-optimizer"
    }
  },
  "framework_integration": {
    "quality_assurance_integration": {
      "performance_regression_testing": true,
      "visual_regression_impact": true,
      "mobile_navigation_performance": true
    },
    "security_compliance_integration": {
      "csp_performance_impact": true,
      "security_header_performance": true,
      "accessibility_performance": true
    },
    "content_release_integration": {
      "pre_deployment_validation": true,
      "blue_green_performance_comparison": true,
      "post_deployment_monitoring": true
    },
    "governance_integration": {
      "authority_matrix_compliance": true,
      "sla_adherence_monitoring": true,
      "emergency_response_coordination": true
    }
  },
  "reporting_configuration": {
    "automated_reports": {
      "daily_performance_summary": true,
      "weekly_trend_analysis": true,
      "monthly_optimization_report": true,
      "incident_post_mortems": true
    },
    "stakeholder_dashboards": {
      "technical_dashboard": "technical-architect",
      "business_dashboard": "project-manager-proj",
      "performance_dashboard": "performance-optimizer"
    },
    "compliance_reporting": {
      "budget_compliance_reports": true,
      "core_web_vitals_reports": true,
      "user_experience_impact_reports": true
    }
  }
}