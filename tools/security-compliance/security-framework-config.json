{
  "framework": "Security & Compliance Framework v1.0",
  "version": "1.0.0",
  "description": "Comprehensive security monitoring and compliance validation for Food-N-Force website",
  "integration": {
    "governance_framework": true,
    "quality_assurance_framework": true,
    "emergency_response_integration": true,
    "technical_architect_authority": true
  },
  "security_monitoring": {
    "content_security_policy": {
      "enabled": true,
      "enforcement_mode": "report-only",
      "transition_to_enforce": true,
      "directives": {
        "default-src": ["'self'"],
        "script-src": ["'self'", "'unsafe-inline'", "'unsafe-eval'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": ["'self'", "data:", "https:"],
        "font-src": ["'self'", "https://fonts.gstatic.com"],
        "connect-src": ["'self'"],
        "frame-ancestors": ["'none'"],
        "base-uri": ["'self'"],
        "form-action": ["'self'"]
      },
      "violation_reporting": {
        "enabled": true,
        "endpoint": "/csp-report",
        "max_reports_per_hour": 100
      }
    },
    "vulnerability_scanning": {
      "enabled": true,
      "scan_frequency": "daily",
      "dependency_audit": {
        "critical_threshold": 0,
        "high_threshold": 2,
        "moderate_threshold": 10,
        "auto_fix": false
      },
      "code_scanning": {
        "enabled": true,
        "patterns": {
          "xss_patterns": [
            "innerHTML\\s*=",
            "outerHTML\\s*=",
            "document\\.write\\s*\\(",
            "eval\\s*\\(",
            "Function\\s*\\(",
            "setTimeout\\s*\\([\"']",
            "setInterval\\s*\\([\"']"
          ],
          "sensitive_data_patterns": [
            "password\\s*[:=]",
            "token\\s*[:=]",
            "api[_-]?key\\s*[:=]",
            "secret\\s*[:=]",
            "bearer\\s+[a-zA-Z0-9]",
            "Authorization:\\s*Bearer"
          ]
        }
      }
    },
    "security_headers": {
      "enabled": true,
      "required_headers": {
        "Content-Security-Policy": "required",
        "X-Frame-Options": "DENY",
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "geolocation=(), microphone=(), camera=()"
      },
      "recommended_headers": {
        "Strict-Transport-Security": "max-age=31536000; includeSubDomains",
        "X-XSS-Protection": "1; mode=block"
      }
    }
  },
  "compliance_validation": {
    "accessibility_compliance": {
      "enabled": true,
      "standard": "WCAG_2_1_AA",
      "automated_testing": true,
      "manual_review_required": true,
      "compliance_threshold": 95,
      "critical_violations": [
        "missing_alt_text",
        "insufficient_color_contrast",
        "missing_form_labels",
        "keyboard_navigation_issues",
        "missing_heading_structure"
      ]
    },
    "data_protection": {
      "enabled": true,
      "gdpr_compliance": {
        "cookie_consent": true,
        "data_retention_policies": true,
        "user_data_deletion": true,
        "privacy_policy_validation": true
      },
      "nonprofit_compliance": {
        "donor_data_protection": true,
        "volunteer_data_handling": true,
        "beneficiary_privacy": true
      }
    },
    "nonprofit_sector_compliance": {
      "enabled": true,
      "fundraising_compliance": {
        "donation_form_security": true,
        "payment_data_protection": true,
        "donor_information_security": true
      },
      "volunteer_management": {
        "background_check_data": true,
        "volunteer_contact_info": true,
        "reference_data_protection": true
      }
    }
  },
  "emergency_security_response": {
    "enabled": true,
    "threat_detection": {
      "real_time_monitoring": true,
      "automated_alerts": true,
      "escalation_thresholds": {
        "critical": "immediate",
        "high": "15min",
        "medium": "1hour",
        "low": "24hour"
      }
    },
    "incident_response": {
      "automated_containment": true,
      "security_rollback": true,
      "breach_notification": true,
      "forensic_logging": true
    },
    "governance_integration": {
      "technical_architect_authority": "15min",
      "security_compliance_auditor": "primary",
      "project_manager_coordination": true,
      "stakeholder_notification": true
    }
  },
  "security_gates": {
    "pre_deployment": {
      "dependency_vulnerability_scan": {
        "enabled": true,
        "blocking": true,
        "critical_threshold": 0,
        "high_threshold": 2
      },
      "code_security_scan": {
        "enabled": true,
        "blocking": true,
        "xss_detection": true,
        "sensitive_data_detection": true
      },
      "csp_validation": {
        "enabled": true,
        "blocking": false,
        "report_violations": true
      },
      "accessibility_compliance": {
        "enabled": true,
        "blocking": false,
        "minimum_score": 95
      },
      "security_headers_validation": {
        "enabled": true,
        "blocking": true,
        "required_headers_present": true
      }
    },
    "post_deployment": {
      "security_monitoring": {
        "enabled": true,
        "csp_violation_monitoring": true,
        "failed_request_monitoring": true,
        "suspicious_activity_detection": true
      },
      "compliance_monitoring": {
        "enabled": true,
        "accessibility_degradation_detection": true,
        "data_protection_validation": true
      }
    }
  },
  "reporting": {
    "security_dashboard": {
      "enabled": true,
      "real_time_metrics": true,
      "compliance_status": true,
      "threat_intelligence": true
    },
    "compliance_reports": {
      "enabled": true,
      "accessibility_reports": true,
      "gdpr_compliance_reports": true,
      "security_posture_reports": true,
      "frequency": "weekly"
    },
    "incident_reports": {
      "enabled": true,
      "automated_generation": true,
      "stakeholder_distribution": true,
      "retention_period": "7_years"
    }
  },
  "governance_integration": {
    "authority_matrix": {
      "security_incidents": {
        "critical": {
          "response_time": "immediate",
          "primary_authority": "technical-architect",
          "secondary_authority": "security-compliance-auditor",
          "escalation": ["project-manager-proj", "stakeholders"]
        },
        "high": {
          "response_time": "15min",
          "primary_authority": "security-compliance-auditor",
          "secondary_authority": "technical-architect",
          "escalation": ["project-manager-proj"]
        },
        "medium": {
          "response_time": "1hour",
          "primary_authority": "security-compliance-auditor",
          "escalation": ["technical-architect"]
        },
        "low": {
          "response_time": "24hour",
          "primary_authority": "security-compliance-auditor"
        }
      },
      "compliance_violations": {
        "accessibility": {
          "response_time": "4hours",
          "primary_authority": "security-compliance-auditor",
          "consultation": ["html-expert-slds", "css-design-systems-expert"]
        },
        "data_protection": {
          "response_time": "1hour",
          "primary_authority": "security-compliance-auditor",
          "escalation": ["technical-architect", "project-manager-proj"]
        }
      }
    },
    "raci_integration": {
      "security_framework_maintenance": {
        "responsible": "security-compliance-auditor",
        "accountable": "technical-architect",
        "consulted": ["devops-cicd-automation"],
        "informed": ["project-manager-proj"]
      },
      "compliance_monitoring": {
        "responsible": "security-compliance-auditor",
        "accountable": "technical-architect",
        "consulted": ["html-expert-slds", "css-design-systems-expert"],
        "informed": ["all-clusters"]
      },
      "security_incident_response": {
        "responsible": "technical-architect",
        "accountable": "technical-architect",
        "consulted": ["security-compliance-auditor"],
        "informed": ["project-manager-proj", "stakeholders"]
      }
    }
  }
}