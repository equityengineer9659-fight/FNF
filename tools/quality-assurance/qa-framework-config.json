{
  "framework": "Quality Assurance Framework v1.0",
  "version": "1.0.0",
  "description": "Automated quality gates and regression detection for Food-N-Force website",
  "
": {
    "governance_integration": true,
    "emergency_response_integration": true,
    "multi_agent_coordination": true,
    "automated_rollback": true
  },
  "quality_gates": {
    "pre_deployment": {
      "visual_regression": {
        "enabled": true,
        "threshold": 0.02,
        "pages": ["index", "about", "services", "resources", "impact", "contact"],
        "viewports": ["mobile", "tablet", "desktop"],
        "zoom_levels": ["100%", "25%"],
        "special_effects": [
          "glassmorphism_navigation",
          "background_spinning_effects", 
          "logo_animations",
          "blue_circular_gradients"
        ]
      },
      "performance_regression": {
        "enabled": true,
        "css_budget": "45KB",
        "js_budget": "90KB",
        "core_web_vitals": {
          "cls": 0.0000,
          "lcp_mobile": "2.5s",
          "fcp": "1.8s"
        }
      },
      "mobile_navigation": {
        "enabled": true,
        "breakpoints": [320, 480, 768, 1024, 1200],
        "critical_functionality": [
          "menu_toggle",
          "dropdown_functionality",
          "keyboard_navigation",
          "touch_interactions"
        ]
      },
      "slds_compliance": {
        "enabled": true,
        "minimum_baseline": 89,
        "token_validation": true,
        "utility_class_conflicts": true
      }
    },
    "post_deployment": {
      "monitoring": {
        "enabled": true,
        "check_interval": "5m",
        "alert_thresholds": {
          "performance_degradation": "10%",
          "error_rate": "1%",
          "availability": "99.9%"
        }
      }
    }
  },
  "regression_detection": {
    "visual": {
      "tool": "playwright",
      "comparison_threshold": 0.02,
      "baseline_directory": "tools/testing/baselines/",
      "output_directory": "tools/quality-assurance/reports/visual/"
    },
    "functional": {
      "tool": "playwright",
      "test_suite": "tools/testing/tests/",
      "parallel_execution": true,
      "retry_attempts": 2
    },
    "performance": {
      "tool": "lighthouse",
      "config": "tools/testing/lighthouserc.json",
      "budget_enforcement": true,
      "trend_analysis": true
    },
    "accessibility": {
      "tool": "pa11y",
      "wcag_level": "AA",
      "automated_fixes": false,
      "integration_tests": true
    }
  },
  "automated_rollback": {
    "triggers": {
      "critical_visual_regression": true,
      "performance_budget_violation": true,
      "mobile_navigation_failure": true,
      "slds_compliance_drop": true,
      "accessibility_regression": true
    },
    "rollback_strategy": "git_reset_hard",
    "verification_tests": [
      "test:critical-navigation",
      "test:performance-budget",
      "test:special-effects"
    ],
    "max_rollback_attempts": 3,
    "emergency_contact": "technical-architect"
  },
  "governance_integration": {
    "authority_matrix": {
      "quality_gate_failures": {
        "response_time": "15min",
        "primary_authority": "technical-architect",
        "escalation_path": ["project-manager-proj", "stakeholders"]
      },
      "regression_detection": {
        "response_time": "30min", 
        "primary_authority": "testing-validation-specialist",
        "consultation_required": ["technical-architect"]
      },
      "rollback_decisions": {
        "response_time": "15min",
        "primary_authority": "technical-architect",
        "notification_required": ["project-manager-proj", "all-cluster-leads"]
      }
    },
    "raci_integration": {
      "qa_framework_maintenance": {
        "responsible": "testing-validation-specialist",
        "accountable": "technical-architect", 
        "consulted": ["qa-automation-engineer"],
        "informed": ["project-manager-proj"]
      },
      "quality_standards_enforcement": {
        "responsible": "qa-automation-engineer",
        "accountable": "technical-architect",
        "consulted": ["performance-optimization-expert"],
        "informed": ["all-clusters"]
      }
    }
  },
  "reporting": {
    "dashboard": {
      "enabled": true,
      "url": "tools/quality-assurance/dashboard/",
      "real_time": true,
      "metrics": [
        "quality_gate_pass_rate",
        "regression_detection_rate", 
        "rollback_frequency",
        "mean_time_to_detection",
        "mean_time_to_recovery"
      ]
    },
    "alerts": {
      "channels": ["console", "file", "webhook"],
      "severity_levels": ["critical", "high", "medium", "low"],
      "escalation_rules": {
        "critical": "immediate",
        "high": "15min",
        "medium": "1hour",
        "low": "24hour"
      }
    }
  }
}