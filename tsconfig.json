{
  "compilerOptions": {
    // Target and Module Configuration
    "target": "ES2020",
    "module": "ES2020", 
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    
    // Output Configuration
    "outDir": "./js/dist-ts",
    "rootDir": "./js/core",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    
    // JavaScript Interoperability (Key for Optional Integration)
    "allowJs": true,
    "checkJs": false,
    "maxNodeModuleJsDepth": 1,
    
    // Strict Type Checking (Progressive - can be enabled gradually)
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "strictBindCallApply": false,
    "strictPropertyInitialization": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "alwaysStrict": false,
    
    // Additional Checks (Helpful but not breaking)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitOverride": false,
    "noPropertyAccessFromIndexSignature": false,
    "noUncheckedIndexedAccess": false,
    
    // Module Detection
    "moduleDetection": "auto",
    
    // Emit Configuration
    "importHelpers": false,
    "downlevelIteration": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    
    // Advanced
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    
    // DOM and Web Components Support
    "customConditions": [],
    
    // Phase 4.1B: Optional TypeScript Integration Settings
    "incremental": true,
    "tsBuildInfoFile": "./js/dist-ts/.tsbuildinfo"
  },
  
  "include": [
    "js/core/**/*.js",
    "js/core/**/*.ts",
    "js/core/**/*.d.ts"
  ],
  
  "exclude": [
    "node_modules",
    "js/dist",
    "js/dist-ts", 
    "tools/testing/**/*",
    "**/*.spec.js",
    "**/*.test.js"
  ],
  
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}