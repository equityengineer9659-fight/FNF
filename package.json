{
  "name": "food-n-force-v2",
  "version": "2.0.0",
  "description": "Food-N-Force - Clean, scalable rebuild with SLDS compliance and premium effects",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "lint:html": "htmlhint \"**/*.html\"",
    "lint:css": "stylelint \"src/css/**/*.css\" --fix",
    "lint:js": "eslint \"src/js/**/*.js\" --fix",
    "lint:fix": "npm run lint:css -- --fix && npm run lint:js -- --fix",
    "test": "npm run test:accessibility && npm run test:performance && npm run test:browser",
    "test:accessibility": "pa11y-ci",
    "test:performance": "lhci autorun --config=tools/testing/lighthouserc.json",
    "test:browser": "playwright test --config=tools/testing/playwright.config.js",
    "validate:html": "html-validate --config tools/testing/html-validate.json \"**/*.html\"",
    "validate:slds": "node tools/deployment/slds-compliance-check.js",
    "security": "npm audit --audit-level moderate",
    "build:full": "npm run lint && npm run validate:html && npm run test && npm run build",
    "serve": "live-server --port=8080 --host=localhost",
    "analyze:bundle": "npx vite-bundle-analyzer",
    "deploy:staging": "netlify deploy",
    "deploy:production": "netlify deploy --prod",
    "rollback": "node tools/deployment/rollback.js",
    "governance:sync": "node tools/governance/sync-governance-docs.js sync",
    "governance:sync:dry": "node tools/governance/sync-governance-docs.js sync --dry-run",
    "governance:sync:force": "node tools/governance/sync-governance-docs.js sync --force",
    "governance:validate": "node tools/governance/sync-governance-docs.js validate",
    "governance:watch": "node tools/governance/governance-hooks.js watch",
    "governance:status": "node tools/governance/governance-hooks.js status",
    "governance:test": "node tools/governance/governance-hooks.js test",
    "governance:rollback": "node tools/governance/sync-governance-docs.js rollback",
    "test:governance": "npm run governance:validate && npm run governance:sync:dry",
    "test:multi-page": "playwright test --config=tools/testing/playwright.config.js",
    "test:special-effects": "playwright test --config=tools/testing/playwright.config.js --grep='special-effects'",
    "test:quality-gates": "node tools/testing/quality-gates.js",
    "test:rollback-validation": "playwright test tools/testing/rollback-validation-protocol.js --config=tools/testing/playwright.config.js",
    "test:rollback-pre": "playwright test --config=tools/testing/playwright.config.js --grep='Pre-Rollback Documentation'",
    "test:rollback-post": "playwright test --config=tools/testing/playwright.config.js --grep='Post-Rollback Validation'",
    "test:performance-budget": "node tools/testing/performance-budget-monitor.js",
    "test:critical-navigation": "playwright test --config=tools/testing/playwright.config.js --grep='Critical navigation smoke test'",
    "ci:rollback-validation": "node tools/testing/rollback-ci-integration.js",
    "setup:rollback-validation": "node tools/testing/setup-rollback-validation.js",
    "test:phase4-framework-evaluation": "playwright test tools/testing/phase4/framework-evaluation/ --config=tools/testing/playwright.config.js",
    "test:phase4-security-hardening": "playwright test tools/testing/phase4/security-hardening/ --config=tools/testing/playwright.config.js",
    "test:phase4-regression-protection": "playwright test tools/testing/phase4/regression-prevention/ --config=tools/testing/playwright.config.js",
    "test:phase4-full-suite": "npm run test:phase4-framework-evaluation && npm run test:phase4-security-hardening && npm run test:phase4-regression-protection",
    "test:phase4-baseline": "npm run test && npm run test:performance-budget && npm run test:critical-navigation",
    "security:csp-validation": "node tools/testing/phase4/security-hardening/csp-validator.js",
    "security:headers-check": "node tools/testing/phase4/security-hardening/security-headers-validator.js",
    "security:vulnerability-scan": "npm audit && node tools/testing/phase4/security-hardening/vulnerability-scanner.js",
    "build:enhanced": "node tools/build/enhanced-build.js",
    "build:typescript": "npx tsc --build",
    "build:phase4": "npm run build:typescript && npm run build:enhanced",
    "phase4:validate": "node tools/testing/phase4-runner.js",
    "phase4:build-test": "npm run build:phase4 && npm run phase4:validate",
    "qa:regression-detection": "node tools/quality-assurance/automated-regression-detector.js",
    "qa:quality-gates": "node tools/quality-assurance/quality-gates.js",
    "qa:emergency-rollback": "node tools/quality-assurance/automated-rollback-system.js",
    "qa:visual-regression": "node tools/quality-assurance/visual-regression-suite.js",
    "qa:rollback-report": "node tools/quality-assurance/automated-rollback-system.js",
    "qa:full-suite": "npm run qa:regression-detection && npm run qa:quality-gates",
    "qa:test": "playwright test tools/testing/tests/qa-visual-regression.spec.js --config=tools/testing/playwright.config.js",
    "qa:setup": "node tools/quality-assurance/visual-regression-suite.js",
    "test:qa": "npm run qa:full-suite && npm run qa:test",
    "security:scan": "node tools/security-compliance/compliance-validation-gates.js",
    "security:compliance": "node tools/security-compliance/compliance-validation-gates.js",
    "security:csp-implement": "node tools/security-compliance/content-security-policy-manager.js",
    "security:csp-analyze": "node tools/security-compliance/content-security-policy-manager.js",
    "security:emergency-response": "node tools/security-compliance/emergency-security-response.js",
    "security:incident-report": "node tools/security-compliance/emergency-security-response.js",
    "compliance:accessibility": "npm run test:accessibility",
    "compliance:gdpr": "echo 'GDPR compliance check - manual review required'",
    "compliance:nonprofit": "echo 'Nonprofit compliance check - manual review required'",
    "compliance:full-audit": "npm run security:compliance",
    "security:full-suite": "npm run security:scan && npm run security:csp-analyze",
    "test:security": "npm run security:full-suite && npm run compliance:accessibility",
    "content:validation": "node tools/content-release/content-lifecycle-manager.js",
    "content:consistency": "node tools/content-release/content-lifecycle-manager.js production",
    "release:orchestration": "node tools/content-release/release-orchestration-system.js",
    "release:gates": "node tools/content-release/release-orchestration-system.js standard",
    "documentation:automation": "node tools/content-release/documentation-automation-system.js",
    "deploy:blue-green": "npm run release:orchestration",
    "deploy:rollback": "node tools/content-release/release-orchestration-system.js rollback",
    "deploy:validate": "npm run content:validation && npm run security:compliance && npm run qa:quality-gates",
    "content:full-suite": "npm run content:validation && npm run content:consistency",
    "release:full-suite": "npm run content:full-suite && npm run release:gates && npm run documentation:automation",
    "performance:monitor": "node tools/performance-optimization/core-performance-monitor.js",
    "performance:analysis": "node tools/performance-optimization/core-performance-monitor.js",
    "performance:budget-enforce": "node tools/performance-optimization/budget-enforcement-system.js",
    "performance:budget-analyze": "node tools/performance-optimization/budget-enforcement-system.js analyze",
    "performance:budget-set-level": "node tools/performance-optimization/budget-enforcement-system.js set-level",
    "performance:vitals-monitor": "node tools/performance-optimization/core-web-vitals-monitor.js start",
    "performance:vitals-status": "node tools/performance-optimization/core-web-vitals-monitor.js status",
    "performance:vitals-single": "node tools/performance-optimization/core-web-vitals-monitor.js",
    "performance:regression-detect": "node tools/performance-optimization/regression-detection-system.js",
    "performance:regression-baseline": "node tools/performance-optimization/regression-detection-system.js establish-baseline",
    "performance:bundle-analyze": "node tools/performance-optimization/bundle-optimizer.js analyze",
    "performance:bundle-report": "node tools/performance-optimization/bundle-optimizer.js report",
    "performance:bundle-optimize": "node tools/performance-optimization/bundle-optimizer.js",
    "performance:emergency-monitor": "node tools/performance-optimization/emergency-response-system.js monitor",
    "performance:emergency-check": "node tools/performance-optimization/emergency-response-system.js check",
    "performance:emergency-status": "node tools/performance-optimization/emergency-response-system.js status",
    "performance:full-suite": "npm run performance:analysis && npm run performance:budget-enforce && npm run performance:regression-detect",
    "performance:monitoring-suite": "npm run performance:vitals-monitor & npm run performance:emergency-monitor",
    "performance:optimize-suite": "npm run performance:bundle-analyze && npm run performance:regression-baseline && npm run performance:budget-set-level STANDARD",
    "phase5:accessibility-assessment": "node tools/security-compliance/accessibility-assessment-tool.js",
    "phase5:security-headers-assessment": "node tools/security-compliance/security-headers-assessment-tool.js",
    "phase5:comprehensive-compliance": "node tools/security-compliance/comprehensive-compliance-monitor.js",
    "phase5:remediation-recommendations": "node tools/security-compliance/remediation-recommendation-system.js",
    "phase5:full-assessment": "npm run phase5:comprehensive-compliance",
    "phase5:emergency-response": "npm run phase5:comprehensive-compliance && npm run phase5:remediation-recommendations",
    "phase6:ai-performance-predict": "node tools/performance-optimization/advanced/ai-performance-predictor.js",
    "phase6:advanced-performance-suite": "npm run phase6:ai-performance-predict",
    "phase7:strategic-roadmap-generate": "node tools/scalability/strategic-roadmap-generator.js",
    "phase7:strategic-planning-suite": "npm run phase7:strategic-roadmap-generate",
    "ecosystem:validate": "node tools/framework-integration/ecosystem-validation-orchestrator.js",
    "ecosystem:health-check": "npm run ecosystem:validate",
    "complete:assessment": "npm run phase5:comprehensive-compliance && npm run phase6:advanced-performance-suite && npm run phase7:strategic-planning-suite && npm run ecosystem:validate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/food-n-force-website.git"
  },
  "keywords": [
    "food-bank",
    "nonprofit",
    "salesforce",
    "slds",
    "accessibility",
    "performance"
  ],
  "author": "Food-N-Force",
  "license": "MIT",
  "devDependencies": {
    "@lhci/cli": "^0.13.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^24.3.0",
    "autoprefixer": "^10.4.0",
    "chokidar": "^3.5.3",
    "cssnano": "^6.0.0",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "glob": "^10.3.0",
    "html-validate": "^8.7.3",
    "htmlhint": "^1.1.4",
    "lighthouse": "^11.4.0",
    "live-server": "^1.2.2",
    "netlify-cli": "^17.10.1",
    "pa11y": "^8.0.0",
    "pa11y-ci": "^3.1.0",
    "postcss": "^8.4.0",
    "stylelint": "^16.0.2",
    "stylelint-config-slds": "^1.0.0",
    "stylelint-config-standard": "^36.0.0",
    "terser": "^5.44.0",
    "typescript": "^5.9.2",
    "vite": "^5.0.0",
    "vite-bundle-analyzer": "^0.7.0",
    "w3c-html-validator": "^1.6.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
