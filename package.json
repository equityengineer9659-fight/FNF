{
  "name": "food-n-force-v2",
  "version": "2.0.0",
  "description": "Food-N-Force - Clean, scalable rebuild with SLDS compliance and premium effects",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "node scripts/generate-sitemap.js && node build-components.js && vite build",
    "build:components": "node build-components.js",
    "build:full": "npm run lint && npm run validate:html && npm run test && npm run build",
    "preview": "vite preview",
    "serve": "live-server --port=4173 --host=localhost",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "lint:html": "htmlhint \"*.html\" \"!playwright-report/**\" \"!lighthouse-reports/**\" \"!dist/**\" \"!tools/testing/playwright-report/**\"",
    "lint:css": "stylelint \"src/css/**/*.css\"",
    "lint:js": "eslint \"src/js/**/*.js\"",
    "lint:fix": "stylelint \"src/css/**/*.css\" --fix && eslint \"src/js/**/*.js\" --fix",
    "test": "npm run test:unit && npm run test:accessibility && npm run test:performance && npm run test:browser",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest run --coverage",
    "test:accessibility": "pa11y-ci",
    "test:performance": "node tools/testing/performance-test.js",
    "test:performance:lighthouse": "node tools/testing/lighthouse-simple.js",
    "test:performance:ci": "lhci autorun --config=lighthouse.config.js",
    "test:performance-budget": "node tools/testing/performance-budget-monitor.js",
    "test:browser": "playwright test --config=tools/testing/playwright.config.js",
    "test:multi-page": "playwright test --config=tools/testing/playwright.config.js",
    "test:critical-navigation": "playwright test --config=tools/testing/playwright.config.js --grep='Critical navigation smoke test'",
    "test:special-effects": "playwright test --config=tools/testing/playwright.config.js --grep='special-effects'",
    "validate:html": "html-validate --config tools/testing/html-validate.json \"*.html\"",
    "validate:slds": "node tools/deployment/slds-compliance-check.js",
    "validate:build": "node tools/deployment/verify-build.js",
    "security": "npm audit --audit-level critical",
    "deps:check": "node tools/dependencies/check-updates.js",
    "deps:update": "node tools/dependencies/auto-update.js",
    "deps:security": "npm audit fix",
    "deps:audit": "npm audit",
    "analyze:bundle": "npx vite-bundle-analyzer",
    "deploy:staging": "netlify deploy",
    "deploy:production": "netlify deploy --prod",
    "rollback": "node tools/deployment/rollback.js",
    "governance:sync": "node tools/governance/sync-governance-docs.js sync",
    "governance:validate": "node tools/governance/sync-governance-docs.js validate",
    "generate:icons": "node scripts/generate-pwa-icons.js",
    "restore:create": "node scripts/create-restore-point.cjs",
    "restore:apply": "node scripts/apply-restore-point.cjs",
    "restore:list": "node -e \"console.log(require('fs').readdirSync('backups').filter(d => d.startsWith('restore_')).sort().reverse().slice(0, 10).join('\\n'))\"",
    "css:duplicates": "node scripts/detect-css-duplicates.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/food-n-force-website.git"
  },
  "keywords": [
    "food-bank",
    "nonprofit",
    "salesforce",
    "slds",
    "accessibility",
    "performance"
  ],
  "author": "Food-N-Force",
  "license": "MIT",
  "devDependencies": {
    "@lhci/cli": "^0.13.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.0",
    "chokidar": "^3.5.3",
    "chrome-launcher": "^1.2.1",
    "cssnano": "^6.0.0",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "glob": "^10.3.0",
    "html-validate": "^8.7.3",
    "htmlhint": "^1.1.4",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lighthouse": "^11.4.0",
    "lint-staged": "^16.4.0",
    "live-server": "^1.2.2",
    "netlify-cli": "^17.10.1",
    "pa11y": "^8.0.0",
    "pa11y-ci": "^3.1.0",
    "postcss": "^8.4.0",
    "puppeteer": "^23.0.0",
    "stylelint": "^16.0.2",
    "stylelint-config-slds": "^1.0.0",
    "stylelint-config-standard": "^36.0.0",
    "terser": "^5.44.0",
    "typescript": "^5.9.2",
    "vite": "^5.0.0",
    "vite-bundle-analyzer": "^0.7.0",
    "vitest": "^3.2.4",
    "w3c-html-validator": "^1.6.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "src/**/*.css": "stylelint",
    "src/**/*.js": "eslint"
  },
  "dependencies": {
    "@sentry/browser": "^10.17.0",
    "pngjs": "^7.0.0"
  }
}
