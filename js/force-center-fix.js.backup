/**
 * Force Center Fix for Focus Areas and Measurable Growth sections
 * PHASE B UPDATE: Disabled - CSS grid solution should handle centering
 * This script forces the correct layout after all other scripts have run
 */

(function() {
    'use strict';
    
    // PHASE B: Temporarily disable JavaScript fixes to test CSS solution
    console.log('🔧 Force-center-fix.js: DISABLED for Phase B testing');
    return;
    
    function forceCenterFix() {
        console.log('🔧 Applying force center fix...');
        
        // Focus Areas section
        const focusGrid = document.querySelector('.index-page section.section-gray .slds-grid');
        const focusContainer = document.querySelector('.index-page section.section-gray .slds-container_large');
        if (focusGrid && focusContainer) {
            // Log current state before changes
            const computedBefore = getComputedStyle(focusGrid);
            const containerComputed = getComputedStyle(focusContainer);
            console.log('Focus Grid BEFORE fix:', {
                display: computedBefore.display,
                width: focusGrid.offsetWidth,
                maxWidth: computedBefore.maxWidth,
                gridTemplateColumns: computedBefore.gridTemplateColumns,
                justifyContent: computedBefore.justifyContent
            });
            console.log('Focus Container:', {
                width: focusContainer.offsetWidth,
                padding: containerComputed.padding,
                paddingLeft: containerComputed.paddingLeft,
                paddingRight: containerComputed.paddingRight
            });
            
            // Remove any inline styles
            focusGrid.removeAttribute('style');
            focusContainer.removeAttribute('style');
            
            // COPY the exact approach from Impact Numbers section
            focusContainer.removeAttribute('style');
            
            // Apply the EXACT same grid approach as Impact Numbers
            focusGrid.style.cssText = `
                display: grid !important;
                grid-template-columns: repeat(3, 1fr) !important;
                gap: 2rem !important;
                max-width: 1200px !important;
                width: 100% !important;
                margin: 0 auto !important;
                justify-content: center !important;
                padding: 0 1rem !important;
                align-items: center !important;
            `;
            
            // Fix columns
            const focusCols = focusGrid.querySelectorAll('.slds-col');
            focusCols.forEach((col, index) => {
                col.removeAttribute('style');
                col.style.cssText = `
                    flex: 0 0 320px !important;
                    width: 320px !important;
                    max-width: 320px !important;
                    margin: 0 !important;
                `;
                console.log(`Focus Col ${index} width:`, col.offsetWidth);
            });
            
            // Log state after changes
            setTimeout(() => {
                const computedAfter = getComputedStyle(focusGrid);
                console.log('Focus Grid AFTER fix:', {
                    display: computedAfter.display,
                    width: focusGrid.offsetWidth,
                    maxWidth: computedAfter.maxWidth,
                    gridTemplateColumns: computedAfter.gridTemplateColumns,
                    justifyContent: computedAfter.justifyContent,
                    inlineStyle: focusGrid.style.cssText
                });
            }, 100);
            
            console.log('✅ Focus Areas section fixed');
        }
        
        // Measurable Growth section
        const measurableGrid = document.querySelector('.index-page section:nth-of-type(3) .slds-grid');
        const measurableContainer = document.querySelector('.index-page section:nth-of-type(3) .slds-container_large');
        if (measurableGrid && measurableContainer) {
            // Remove any inline styles
            measurableGrid.removeAttribute('style');
            measurableContainer.removeAttribute('style');
            
            // COPY the exact approach from Impact Numbers section
            measurableContainer.removeAttribute('style');
            
            // Apply the EXACT same grid approach as Impact Numbers
            measurableGrid.style.cssText = `
                display: grid !important;
                grid-template-columns: repeat(3, 1fr) !important;
                gap: 2rem !important;
                max-width: 1200px !important;
                width: 100% !important;
                margin: 0 auto !important;
                justify-content: center !important;
                padding: 0 1rem !important;
                align-items: center !important;
            `;
            
            // Fix columns
            const measurableCols = measurableGrid.querySelectorAll('.slds-col');
            measurableCols.forEach(col => {
                col.removeAttribute('style');
                col.style.cssText = `
                    flex: 0 0 320px !important;
                    width: 320px !important;
                    max-width: 320px !important;
                    margin: 0 !important;
                `;
            });
            
            console.log('✅ Measurable Growth section fixed');
        }
    }
    
    // Run immediately
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', forceCenterFix);
    } else {
        // DOM already loaded
        setTimeout(forceCenterFix, 100);
    }
    
    // Run again after all other scripts
    window.addEventListener('load', function() {
        setTimeout(forceCenterFix, 500);
        // One more time to be sure
        setTimeout(forceCenterFix, 1500);
    });
    
    // Make it available globally for testing
    window.forceCenterFix = forceCenterFix;
})();