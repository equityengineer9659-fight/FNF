/**
 * Grid Layout Diagnostic Tool
 * Diagnoses the Focus Areas and Measurable Growth sections
 */

function diagnoseGridLayouts() {
    console.group('%c🔍 GRID LAYOUT DIAGNOSTICS', 'font-size: 16px; font-weight: bold; color: #2196F3;');
    
    // Check Focus Areas section
    console.group('%c📦 Focus Areas Section', 'font-size: 14px; font-weight: bold; color: #10B981;');
    const focusSection = document.querySelector('.index-page section.section-gray');
    if (focusSection) {
        const focusContainer = focusSection.querySelector('.slds-container_large');
        const focusGrid = focusSection.querySelector('.slds-grid');
        const focusCols = focusSection.querySelectorAll('.slds-col');
        
        console.log('Container:', {
            width: focusContainer?.offsetWidth,
            computedStyle: getComputedStyle(focusContainer),
            classes: focusContainer?.className
        });
        
        console.log('Grid:', {
            width: focusGrid?.offsetWidth,
            display: getComputedStyle(focusGrid)?.display,
            gridTemplateColumns: getComputedStyle(focusGrid)?.gridTemplateColumns,
            justifyContent: getComputedStyle(focusGrid)?.justifyContent,
            gap: getComputedStyle(focusGrid)?.gap,
            classes: focusGrid?.className
        });
        
        console.log('Columns:', {
            count: focusCols.length,
            widths: Array.from(focusCols).map(col => col.offsetWidth),
            classes: focusCols[0]?.className
        });
        
        // Check what CSS is actually being applied
        const appliedStyles = getComputedStyle(focusGrid);
        console.log('Applied Grid Styles:', {
            display: appliedStyles.display,
            gridTemplateColumns: appliedStyles.gridTemplateColumns,
            flexWrap: appliedStyles.flexWrap,
            justifyContent: appliedStyles.justifyContent,
            maxWidth: appliedStyles.maxWidth,
            margin: appliedStyles.margin
        });
    }
    console.groupEnd();
    
    // Check Measurable Growth section
    console.group('%c📊 Measurable Growth Section', 'font-size: 14px; font-weight: bold; color: #F59E0B;');
    const measurableSection = document.querySelector('.index-page section:nth-of-type(3)');
    if (measurableSection) {
        const measurableContainer = measurableSection.querySelector('.slds-container_large');
        const measurableGrid = measurableSection.querySelector('.slds-grid');
        const measurableCols = measurableSection.querySelectorAll('.slds-col');
        
        console.log('Container:', {
            width: measurableContainer?.offsetWidth,
            computedStyle: getComputedStyle(measurableContainer),
            classes: measurableContainer?.className
        });
        
        console.log('Grid:', {
            width: measurableGrid?.offsetWidth,
            display: getComputedStyle(measurableGrid)?.display,
            gridTemplateColumns: getComputedStyle(measurableGrid)?.gridTemplateColumns,
            justifyContent: getComputedStyle(measurableGrid)?.justifyContent,
            gap: getComputedStyle(measurableGrid)?.gap,
            classes: measurableGrid?.className
        });
        
        console.log('Columns:', {
            count: measurableCols.length,
            widths: Array.from(measurableCols).map(col => col.offsetWidth),
            classes: measurableCols[0]?.className
        });
        
        // Check what CSS is actually being applied
        const appliedStyles = getComputedStyle(measurableGrid);
        console.log('Applied Grid Styles:', {
            display: appliedStyles.display,
            gridTemplateColumns: appliedStyles.gridTemplateColumns,
            flexWrap: appliedStyles.flexWrap,
            justifyContent: appliedStyles.justifyContent,
            maxWidth: appliedStyles.maxWidth,
            margin: appliedStyles.margin
        });
    }
    console.groupEnd();
    
    // Check Impact Numbers section for comparison
    console.group('%c💯 Impact Numbers Section (Working)', 'font-size: 14px; font-weight: bold; color: #8B5CF6;');
    const impactSection = document.querySelector('.index-page .impact-numbers-dark');
    if (impactSection) {
        const impactGrid = impactSection.querySelector('.slds-grid');
        const impactCols = impactSection.querySelectorAll('.slds-col');
        
        console.log('Grid:', {
            width: impactGrid?.offsetWidth,
            display: getComputedStyle(impactGrid)?.display,
            gridTemplateColumns: getComputedStyle(impactGrid)?.gridTemplateColumns,
            classes: impactGrid?.className
        });
        
        console.log('Columns:', {
            count: impactCols.length,
            widths: Array.from(impactCols).map(col => col.offsetWidth)
        });
    }
    console.groupEnd();
    
    // Check for interfering JavaScript
    console.group('%c⚠️ JavaScript Style Modifications', 'font-size: 14px; font-weight: bold; color: #DC2626;');
    const allElements = document.querySelectorAll('.focus-area-card, .measurable-card, .slds-grid, .slds-col');
    let jsModified = [];
    allElements.forEach(el => {
        if (el.style.cssText) {
            jsModified.push({
                element: el.className,
                inlineStyles: el.style.cssText
            });
        }
    });
    
    if (jsModified.length > 0) {
        console.table(jsModified);
    } else {
        console.log('✅ No inline styles detected');
    }
    console.groupEnd();
    
    console.groupEnd();
}

// Run diagnostics when page loads
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', diagnoseGridLayouts);
} else {
    // Page already loaded
    setTimeout(diagnoseGridLayouts, 1000);
}

// Make it available globally
window.diagnoseGridLayouts = diagnoseGridLayouts;